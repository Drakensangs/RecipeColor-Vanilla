<Ui xmlns = "http://www.blizzard.com/wow/ui/"
	xmlns:xsi = "http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation = "http://www.blizzard.com/wow/ui/C:\Projects\WoW\Bin\Interface\FrameXML\UI.xsd">

<Frame name = "RecipeColor" parent = "UIParent" hidden = "false">
	<Scripts>
		<OnLoad>
			RecipeColor_OnLoad()
			this:RegisterEvent("ADDON_LOADED")
		</OnLoad>
		<OnEvent>
			RecipeColor_OnEvent(this, event, arg1)
		</OnEvent>
	</Scripts>
</Frame>

<GameTooltip name = "RecipeColor_ScanTooltip" inherits = "GameTooltipTemplate">
	<Scripts>
		<Onload>
			this:SetOwner(WorldFrame, "ANCHOR_NONE")
		</Onload>
	</Scripts>
</GameTooltip>
</Ui>
